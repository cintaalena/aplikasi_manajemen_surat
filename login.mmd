sequenceDiagram
    actor User as Pengguna
    participant App as Aplikasi
    participant DB as Database
    participant Log as Log Keamanan

    User->>App: Buka halaman login
    App->>DB: Ambil daftar nama pengguna aktif
    DB-->>App: Daftar nama pengguna
    App-->>User: Tampilkan halaman login

    User->>App: Kirim nama, password, dan kode kredensial

    alt Terlalu banyak percobaan login
        App->>Log: Catat pelanggaran batas percobaan
        App-->>User: Ditolak — coba lagi dalam beberapa detik

    else Batas percobaan masih aman
        App->>DB: Cari pengguna berdasarkan nama

        alt Pengguna tidak ditemukan
            App->>Log: Catat percobaan login gagal
            App-->>User: Ditolak — nama atau password salah

        else Pengguna ditemukan
            App->>DB: Periksa apakah akun sedang dikunci

            alt Akun sedang dikunci
                App->>Log: Catat akun dikunci
                App-->>User: Ditolak — akun dikunci, coba lagi dalam N menit

            else Akun tidak dikunci
                App->>App: Verifikasi password dan kode kredensial

                alt Password atau kode kredensial salah
                    App->>DB: Tambah hitungan percobaan gagal
                    App->>Log: Catat login gagal
                    App-->>User: Ditolak — nama atau password salah

                else Semua verifikasi berhasil
                    App->>DB: Reset hitungan percobaan gagal
                    App->>Log: Catat login berhasil
                    App->>App: Buat sesi baru
                    App-->>User: Arahkan ke halaman dashboard
                end
            end
        end
    end
