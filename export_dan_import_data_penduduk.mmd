sequenceDiagram
    actor User as Pengguna
    participant App as Aplikasi
    participant DB as Database

    %% ── EKSPOR DATA PENDUDUK ──────────────────────────────
    User->>App: Buka halaman data penduduk dan atur filter (dusun, RT, RW, nama)
    User->>App: Klik tombol Ekspor

    App->>DB: Ambil data penduduk sesuai filter (kecuali yang sudah meninggal)
    DB-->>App: Data penduduk yang sesuai
    App->>App: Susun data ke dalam format CSV
    App-->>User: Unduh file CSV berisi data penduduk

    %% ── IMPOR DATA PENDUDUK ───────────────────────────────
    User->>App: Klik tombol Impor lalu pilih file (CSV atau Excel)

    alt File melebihi 10 MB
        App-->>User: Tolak — ukuran file terlalu besar
    else Format file tidak didukung
        App-->>User: Tolak — gunakan format CSV, XLSX, atau XLS
    else File valid
        App->>App: Baca isi file dan kenali kolom-kolomnya secara otomatis

        alt Kolom wajib tidak ditemukan
            App-->>User: Tolak — kolom Nama atau Kode Keluarga tidak ada di file
        else File siap diproses
            App->>DB: Mulai proses penyimpanan data (semua baris berhasil atau dibatalkan semua)

            loop Setiap baris data dalam file
                alt Baris kosong atau tidak lengkap
                    App->>App: Lewati baris ini
                else NIK sudah terdaftar di database
                    App->>DB: Perbarui data penduduk yang sudah ada
                else Nama dan Kode Keluarga sudah terdaftar
                    App->>DB: Perbarui data penduduk yang sudah ada
                else Data baru
                    App->>DB: Tambahkan sebagai penduduk baru
                end
            end

            alt Terjadi kesalahan saat menyimpan
                App->>DB: Batalkan semua perubahan
                App-->>User: Impor gagal — tampilkan penyebab kesalahan
            else Semua data berhasil disimpan
                App->>DB: Konfirmasi simpan semua perubahan
                App-->>User: Impor selesai — tampilkan ringkasan (berhasil ditambah, diperbarui, dilewati)
            end
        end
    end
