sequenceDiagram
    actor Staff as Staff
    actor Lurah as Lurah
    participant App as Aplikasi
    participant DB as Database

    %% ── BUKA FORMULIR DAN UNGGAH DOKUMEN ─────────────────
    Staff->>App: Buka formulir cetak surat
    App-->>Staff: Tampilkan template surat

    opt Ada dokumen pendukung
        Staff->>App: Unggah dokumen pendukung (foto/PDF)
        alt File tidak valid atau berbahaya
            App-->>Staff: Tolak unggahan, tampilkan pesan kesalahan
        else File valid
            App->>DB: Simpan dokumen sementara
            App-->>Staff: Dokumen berhasil diunggah
        end
    end

    %% ── KLIK CETAK ────────────────────────────────────────
    Staff->>App: Isi data surat lalu klik Cetak
    App->>App: Periksa kelengkapan data dan dokumen persyaratan

    alt Data atau dokumen belum lengkap
        App-->>Staff: Tampilkan pesan kesalahan
    else Semua lengkap
        App-->>Staff: Buka dialog cetak browser
        Staff->>App: Cetak ke printer atau simpan sebagai PDF
        App-->>Staff: Muncul konfirmasi — apakah surat sudah berhasil dicetak?

        alt Staff memilih Tidak / Batal
            App-->>Staff: Kembali ke formulir, surat tidak disimpan ke arsip
        else Staff memilih Ya, sudah tercetak

            %% ── SIMPAN KE ARSIP BERDASARKAN JENIS SURAT ──────────
            alt Surat Keterangan Domisili
                App->>DB: Cek apakah nama pemohon terdaftar di data penduduk
                alt Nama tidak ditemukan
                    App-->>Staff: Tolak — nama tidak terdaftar
                else Nama terdaftar
                    App->>DB: Buat nomor surat otomatis dan simpan surat
                    App->>DB: Tautkan dokumen pendukung ke surat
                    App->>DB: Kirim notifikasi ke Lurah
                    App-->>Staff: Surat tersimpan di arsip
                end

            else Surat Keterangan Kematian
                App->>DB: Cek apakah nama pemohon terdaftar di data penduduk
                alt Nama tidak ditemukan
                    App-->>Staff: Tolak — nama tidak terdaftar
                else Nama terdaftar
                    App->>DB: Buat nomor surat otomatis dan simpan surat
                    App->>DB: Ubah status penduduk menjadi Meninggal
                    App->>DB: Tautkan dokumen pendukung ke surat
                    App->>DB: Kirim notifikasi ke Lurah
                    App-->>Staff: Surat tersimpan — status penduduk berubah menjadi Meninggal
                end

            else Surat Keterangan Pindah
                App->>DB: Cek apakah nama pemohon terdaftar di data penduduk
                alt Nama tidak ditemukan
                    App-->>Staff: Tolak — nama tidak terdaftar
                else Nama terdaftar
                    App->>DB: Buat nomor surat otomatis dan simpan surat
                    App->>DB: Ubah status pemohon dan anggota keluarga yang ikut menjadi Pindah
                    Note over App,DB: Data penduduk yang pindah tidak lagi muncul di daftar penduduk
                    App->>DB: Tautkan dokumen pendukung ke surat
                    App->>DB: Kirim notifikasi ke Lurah
                    App-->>Staff: Surat tersimpan — data penduduk yang pindah hilang dari daftar
                end

            else Surat Kelahiran
                App->>DB: Buat nomor surat otomatis dan simpan surat
                App->>DB: Daftarkan bayi sebagai penduduk baru (nama, NIK, tanggal lahir, data keluarga)
                Note over App,DB: Data bayi diambil otomatis dari data ayah atau ibu yang sudah terdaftar
                App->>DB: Tautkan dokumen pendukung ke surat
                App->>DB: Kirim notifikasi ke Lurah
                App-->>Staff: Surat tersimpan — data bayi otomatis masuk ke database penduduk

            else Jenis surat lainnya
                App->>DB: Buat nomor surat otomatis dan simpan surat
                App->>DB: Tautkan dokumen pendukung ke surat
                App->>DB: Kirim notifikasi ke Lurah
                App-->>Staff: Surat tersimpan di arsip
            end

            alt Nomor surat sudah dipakai surat lain
                App-->>Staff: Nomor surat diubah otomatis ke nomor berikutnya, silakan cetak ulang
            else Semua berhasil disimpan
                App-->>Staff: Diarahkan ke halaman dashboard
                App-->>Lurah: Notifikasi surat baru masuk
            end

        end
    end
